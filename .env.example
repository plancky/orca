# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workspace_orchestrator

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Inference (external, OpenAI-compatible; app image stays CPU-only) ----
INFERENCE_BASE_URL=http://localhost:11434
CHAT_MODEL=llama3
EMBED_MODEL=nomic-embed-text
RERANK_MODEL=bge-reranker-v2-m3
EMBED_DIM=1024

# ---- Embedding mode: "fake" (deterministic, offline) | "real" ----
EMBED_MODE=fake
RERANK_ENABLED=false

# ---- Sync beat ----
SYNC_BEAT_MINUTES=15

# ---- Auth ----
# REQUIRED in production (no default). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=

# ---- App ----
API_V1_STR=/api/v1
DEFAULT_TZ=America/New_York
PROVIDER=mock
RATE_LIMIT_PER_USER_PER_HOUR=100
