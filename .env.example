DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workspace_orchestrator
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
# Gemini (Google AI Studio) — free key: https://aistudio.google.com/apikey. Required only for EMBED_MODE=real / live.
GEMINI_STUDIO_API_KEY=
INFERENCE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001
EMBED_MODE=fake
# --- Chat inference provider (Adapter pattern) ---
# LLM_PROVIDER=auto routes to Modal/Qwen when LLM_BASE_URL is set, else Gemini.
# Force explicitly with LLM_PROVIDER=modal_qwen or LLM_PROVIDER=gemini.
LLM_PROVIDER=auto
# Modal-hosted OpenAI-compat endpoint incl. version segment, e.g. https://<app>.modal.direct/v1
LLM_BASE_URL=
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
# Modal proxy auth (sent as Modal-Key / Modal-Secret headers).
MODAL_PROXY_TOKEN_ID=
MODAL_PROXY_TOKEN_SECRET=
# BGE embedder — separate Modal service, SAME MODAL_PROXY_TOKEN_* pair above.
# Set EMBED_MODE=real + EMBED_MODEL=BAAI/bge-large-en to route embeddings here.
EMBEDDER_BASE_URL=
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=
