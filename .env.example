DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workspace_orchestrator
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
# EMBED_MODE=fake runs fully offline (deterministic FakeEmbedder, no API key).
# Flip to "real" to use the Modal backend below.
EMBED_MODE=fake

# --- Real inference + embeddings backend: Modal (Qwen chat + BGE embeddings) ---
# Modal is the real LLM/embedding provider for this project. Set these plus
# EMBED_MODE=real to run live. LLM_PROVIDER=modal_qwen forces the Modal chat
# adapter (auth via Modal-Key / Modal-Secret headers).
LLM_PROVIDER=modal_qwen
# Modal-hosted OpenAI-compat chat endpoint incl. version segment, e.g. https://<app>.modal.direct/v1
LLM_BASE_URL=
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
# BGE embedder — separate Modal service, SAME MODAL_PROXY_TOKEN_* pair below.
EMBEDDER_BASE_URL=
# Modal proxy auth — shared by the chat + embedder services.
MODAL_PROXY_TOKEN_ID=
MODAL_PROXY_TOKEN_SECRET=

# --- Gemini (Google AI Studio) — OPTIONAL fallback, only if LLM_PROVIDER=gemini ---
# Free key: https://aistudio.google.com/apikey.
GEMINI_STUDIO_API_KEY=
INFERENCE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=

# --- Phase 2: real Google Workspace providers ---
# PROVIDER=google switches the data plane from the mock corpus to live Gmail/
# Calendar/Drive. Requires EMBED_MODE=real so corpus + query share a vector space.
PROVIDER=mock
# OAuth 2.0 Web client (Google Cloud Console -> APIs & Services -> Credentials).
# redirect_uri is served by the backend but registered at the Vite SPA origin; the
# dev server proxies /api/v1 -> :8000 (see frontend/vite.config.ts). Must EXACTLY
# match an "Authorized redirect URI" on the OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/v1/auth/callback
# SPA origin the OAuth callback redirects back to (JWT handed off in the URL fragment).
FRONTEND_URL=http://localhost:5173
# Fernet key encrypting stored Google tokens:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
# Writes are simulated unless set false (safe demos).
DRY_RUN_WRITES=true
# For http://localhost dev redirects the backend auto-relaxes oauthlib
# (OAUTHLIB_INSECURE_TRANSPORT + OAUTHLIB_RELAX_TOKEN_SCOPE). Never uses http in prod.
